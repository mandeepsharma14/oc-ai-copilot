# ============================================================
# OC AI Copilot — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Application
ENVIRONMENT=development
SECRET_KEY=your-secret-key-minimum-32-characters-long
LOG_LEVEL=INFO

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_EMBED=text-embedding-3-large

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_INTERNAL=oc-internal-docs
AZURE_SEARCH_INDEX_EXTERNAL=oc-external-docs

# Azure Entra ID (Internal employee SSO)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Redis Cache
REDIS_URL=redis://localhost:6379

# Azure Cosmos DB (Sessions + Audit)
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=oc-copilot

# Azure SQL (Structured audit log)
AZURE_SQL_CONNECTION_STRING=Server=your-server.database.windows.net;Database=oc-audit;...

# Azure Blob Storage (Document storage)
AZURE_STORAGE_ACCOUNT=yourstorageaccount
AZURE_STORAGE_KEY=your-storage-key
AZURE_STORAGE_CONTAINER_INTERNAL=internal-docs
AZURE_STORAGE_CONTAINER_EXTERNAL=external-docs

# Frontend (Next.js public vars)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AZURE_CLIENT_ID=your-client-id
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id
NEXT_PUBLIC_STREAM_TYPE=internal

# RAG Settings
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_RERANK=6
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=102
RAG_MIN_CONFIDENCE=0.35
